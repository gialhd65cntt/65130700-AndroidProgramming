<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F9FF"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÍNH TOÁN HÌNH CHỮ NHẬT"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/edtChieuDai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập chiều dài (m)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/edtChieuRong"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập chiều rộng (m)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnChuVi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TÍNH CHU VI"
            android:backgroundTint="#4CAF50"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btnDienTich"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TÍNH DIỆN TÍCH"
            android:backgroundTint="#FF9800"
            android:layout_marginStart="5dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtKetQua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kết quả sẽ hiển thị ở đây"
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:padding="20dp"
        android:background="#FFFFFF"
        android:elevation="2dp"/>

</LinearLayout>